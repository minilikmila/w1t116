    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "svelte-spa-router": "^5.0.1"
